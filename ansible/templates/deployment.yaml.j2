apiVersion: apps/v1
kind: Deployment
metadata:
  name: tp4-app
  labels:
    app: tp4-app
spec:
  replicas: 2
  selector:
    matchLabels:
      app: tp4-app
  template:
    metadata:
      labels:
        app: tp4-app
    spec:
      containers:
      - name: tp4-app
        image: "{{ docker_image }}:{{ build_number }}"
        imagePullPolicy: Always
        ports:
        - containerPort: 3000
